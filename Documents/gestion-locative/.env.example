# Supabase Configuration
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs

# URL de votre projet Supabase
# Trouvable sur: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Clé publique anonyme (anon key)
# Trouvable sur: Supabase Dashboard > Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Note: Ne jamais commiter le fichier .env dans Git !
# Le .gitignore doit contenir .env
